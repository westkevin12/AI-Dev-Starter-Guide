{
  "name": "AI Development Environment",
  "description": "Professional-grade AI Workstation for sovereign agents.",
  "machine": {
    "os": "ubuntu-24.04",
    "gpu": "nvidia",
    "cpu": 4,
    "ram_gb": 32,
    "storage_gb": 100
  },
  "dependencies": {
    "apt_packages": [
      "make", "build-essential", "libssl-dev", "git", "gh", "docker.io", "zstd"
    ],
    "python": { "version": "3.11.9", "manager": "pyenv" },
    "node": { "version": "lts", "manager": "nvm" },
    "npm_globals": ["@google/gemini-cli"]
  },
  "tools": [
    {
      "name": "Google Cloud SDK",
      "type": "cli",
      "install_method": "apt",
      "package": "google-cloud-cli"
    }
  ],
  "capabilities": {
    "on_demand": [
      {
        "name": "Local Inference (Ollama)",
        "trigger_condition": "intent:local_llm_task",
        "install_script": "curl -fsSL https://ollama.com/install.sh | sh"
      }
    ]
  },
  "identity": {
    "description": "Workload Identity bindings for GCP access.",
    "workload_identity_pool": "${GCP_WORKLOAD_IDENTITY_POOL}",
    "provider_id": "${GCP_PROVIDER_ID}"
  }
}
